#!/bin/sh /etc/rc.common

START=95
STOP=10
USE_PROCD=1

EXTRA_COMMANDS="login sstatus"
EXTRA_HELP="        login   Run a one-shot portal login now
        sstatus  Print current connectivity/portal status"

get_config() {
    config_load campusportal
    config_get enabled config enabled 0
    config_get USERNAME config username ''
    config_get PASSWORD config password ''
    config_get SERVICE config service ''
    config_get INTERFACE config interface 'eth1'
    config_get MONITOR_INTERVAL config monitor_interval 60
    config_get RETRY_MAX config retry_max 3
    config_get RETRY_SLEEP config retry_sleep 2
    config_get CAPTIVE_URL config captive_url 'http://www.google.cn/generate_204'
    config_get CURL_UA config user_agent 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.3163.91 Safari/537.36'
}

is_online() {
    local http_code
    http_code=$(curl -s -I -m 10 -o /dev/null -w "%{http_code}" --interface "$INTERFACE" "$CAPTIVE_URL" 2>/dev/null)
    [ "$http_code" = "204" ]
}

do_login_once() {
    echo "[campusportal] Probing connectivity..."
    if is_online; then
        echo "[campusportal] Already online."
        return 0
    fi

    echo "[campusportal] Not online, fetching portal redirect page..."
    local portal_content
    portal_content=$(curl -fsS --connect-timeout 5 --max-time 10 --interface "$INTERFACE" "$CAPTIVE_URL" -A "$CURL_UA" 2>/dev/null || true)
    if [ -z "$portal_content" ]; then
        echo "[campusportal] ERROR: empty response from $CAPTIVE_URL"
        return 1
    fi

    local loginPageURL
    loginPageURL=$(echo "$portal_content" | awk -F \' '{print $2}')
    if [ -z "$loginPageURL" ]; then
        echo "[campusportal] ERROR: failed to extract loginPageURL"
        return 1
    fi
    echo "[campusportal] Got loginPageURL: $loginPageURL"

    local queryString
    queryString=$(echo "$loginPageURL" | awk -F '?' '{print $2}')
    if [ -z "$queryString" ]; then
        echo "[campusportal] ERROR: no queryString in loginPageURL"
        return 1
    fi

    queryString="${queryString//&/%2526}"
    queryString="${queryString//=/%253D}"
    echo "[campusportal] Processed queryString (len=${#queryString})"

    local loginURL
    loginURL=$(echo "$loginPageURL" | awk -F '?' '{print $1}')
    loginURL="${loginURL/index.jsp/InterFace.do?method=login}"
    echo "[campusportal] Login URL: $loginURL"

    local post_data
    post_data="userId=$USERNAME&password=$PASSWORD&service=$SERVICE&queryString=$queryString&operatorPwd=&operatorUserId=&validcode=&passwordEncrypt=false"

    echo "[campusportal] Logging in..."
    local login_json
    login_json=$(curl -fsS --connect-timeout 5 --max-time 10 --interface "$INTERFACE" -X POST "$loginURL" \
        -H "User-Agent: $CURL_UA" \
        -H "Referer: $loginPageURL" \
        -H "Accept: text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,image/apng,*/*;q=0.8" \
        -H "Content-Type: application/x-www-form-urlencoded; charset=UTF-8" \
        --data "$post_data" 2>/dev/null || true)

    if echo "$login_json" | grep -q '"result":"success"'; then
        echo "[campusportal] Login success."
        return 0
    else
        echo "[campusportal] Login failed."
        echo "$login_json" | sed -n 's/.*"message":"\([^"]*\)".*/[campusportal] reason: \1/p'
        return 2
    fi
}

start_service() {
    get_config

    if [ "$enabled" != "1" ]; then
        echo "[campusportal] Service is disabled."
        return 1
    fi

    echo "[campusportal] Starting campus portal monitor..."
    echo `date +%s` > /tmp/campusportal_uptime

    procd_open_instance
    procd_set_param command /bin/sh -c "
MONITOR_INTERVAL=${MONITOR_INTERVAL}
RETRY_MAX=${RETRY_MAX}
RETRY_SLEEP=${RETRY_SLEEP}
CAPTIVE_URL=\"${CAPTIVE_URL}\"
CURL_UA=\"${CURL_UA}\"
INTERFACE=\"${INTERFACE}\"

is_online() {
    http_code=\$(curl -s -I -m 10 -o /dev/null -w \"%{http_code}\" --interface \"\$INTERFACE\" \"\$CAPTIVE_URL\" 2>/dev/null)
    [ \"\$http_code\" = \"204\" ]
}

while true; do
    if is_online; then
        sleep \"\$MONITOR_INTERVAL\"
        continue
    fi

    echo \"[campusportal] offline detected, trying to login...\"
    tries=1
    rc=1
    while [ \"\$tries\" -le \"\$RETRY_MAX\" ]; do
        /etc/init.d/campusportal login && { rc=0; break; }
        sleep \"\$RETRY_SLEEP\"
        tries=\$((tries+1))
    done
    if [ \"\$rc\" -ne 0 ]; then
        echo \"[campusportal] auto-login failed after \$RETRY_MAX tries.\"
    fi
    sleep \"\$MONITOR_INTERVAL\"
done
"
    procd_set_param respawn 5 1 60
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

stop_service() {
    return 0
}

reload_service() {
    stop
    start
}

service_triggers() {
    procd_add_reload_trigger "network" "wireless"
}

login() {
    get_config
    do_login_once
}

sstatus() {
    get_config
    if is_online; then
        echo "[campusportal] Online"
    else
        echo "[campusportal] Offline"
    fi
}